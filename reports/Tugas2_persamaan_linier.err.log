b = np.array([6, 14, 14], dtype=float)
print(b)

n = len(b)

# Forward Elimination
for i in range(n):
    for j in range(i+1, n):
        ratio = A[j][i] / A[i][i]
        A[j] = A[j] - ratio * A[i]
        b[j] = b[j] - ratio * b[i]

# Back Substitution
